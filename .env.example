# ProcureFlow environment configuration
# Never commit real production secrets. Copy to .env and use a secret manager in production.
PROCUREFLOW_PRODUCTION=0
PROCUREFLOW_SESSION_TIMEOUT_MINUTES=60
# Optional: stable secret used to encrypt the local browser session cookie.
# In production set this to an independently rotated high-entropy value.
PROCUREFLOW_SESSION_COOKIE_SECRET=
PROCUREFLOW_LOGIN_LOCKOUT_ATTEMPTS=5
PROCUREFLOW_PASSWORD_HISTORY_COUNT=5
PROCUREFLOW_DATA_DIR=data
PROCUREFLOW_UPLOAD_DIR=data/uploads
PROCUREFLOW_BACKUP_DIR=data/backups
PROCUREFLOW_MAX_UPLOAD_MB=15
PROCUREFLOW_MAX_ZIP_MEMBERS=2000
PROCUREFLOW_MAX_ZIP_UNCOMPRESSED_MB=100
PROCUREFLOW_ENABLE_AV_SCAN=0

# Required when PROCUREFLOW_PRODUCTION=1. Use independently rotated high-entropy values.
PROCUREFLOW_PAYEE_ENCRYPTION_KEY=
PROCUREFLOW_AUDIT_SIGNING_KEY=

# Email/notification delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
